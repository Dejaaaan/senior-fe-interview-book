{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["cdk/**/*.ts", "api/**/*.ts"]
}
