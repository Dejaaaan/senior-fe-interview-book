/.quarto/
**/*.quarto_ipynb

# Generated by scripts/preprocess.py on every render. Mirrors ../content/ with
# Quarto-specific transformations: Mermaid blocks are pre-rendered to PNG and
# replaced with image references; .md files are renamed to .qmd; internal
# Markdown links are rewritten from .md to .qmd.
/content/

# Cached PNGs for the pre-rendered Mermaid diagrams. Keyed by SHA-256 of each
# block's source so unchanged diagrams are skipped on re-renders. Populated by
# scripts/preprocess.py; safe to delete to force a full re-render.
/.mermaid-cache/
